{
  "name": "portfolio-monorepo",
  "private": true,
  "packageManager": "pnpm@10.34.1",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@portfolio/web",
    "dev:api": "turbo run dev --filter=@portfolio/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@nestjs/core", "@parcel/watcher", "@swc/core", "esbuild"]
  }
}

